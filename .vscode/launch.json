{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "DOFLUXO Web (sessão Google persistente)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-port=8080",
        "--web-browser-flag=--user-data-dir=${workspaceFolder}/.dart_tool/chrome-dev-profile"
      ]
    }
  ]
}
